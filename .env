# 复制为 .env 并修改
# 安装阶段先执行：huggingface-cli download Qwen/Qwen3-ASR-1.7B
# ASR_MODEL_PATH 填模型 ID，勿填 .cache/.../snapshots/... 路径
ASR_MODEL_PATH=Qwen/Qwen3-ASR-1.7B
GPU_MEMORY_UTILIZATION=0.8
# 实时 ASR 无需 65536 默认上下文，4000 可显著降低 KV cache 占用
MAX_MODEL_LEN=4000
MAX_NEW_TOKENS=32
# 预下载模型后设为 true，离线启动
HF_HUB_OFFLINE=true
HOST=0.0.0.0
PORT=9800
